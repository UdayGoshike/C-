// Online C++ compiler to run C++ program online
#include <bits/stdc++.h>
using namespace std;
int main() {
   string n;
   cin>>n;
   set<int>s;
   for(int i=0;i<n.size();i++){
       int c=0;
       for(int j=0;j<n.size();j++){
           if(n[j]-'0'==i){
               c++;
           }
       }
       if(c!=n[i]-'0'){
           return 0;
       }else if (c==n[i]-'0'){
           s.insert(n[i]);
       }
       
   }
   cout<<s.size()<<endl;

    return 0;
}
